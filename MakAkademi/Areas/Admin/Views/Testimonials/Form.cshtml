@model MakAkademi.Models.Entities.Testimonial
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Yorum Düzenle" : "Yeni Yorum Ekle";
    ViewData["PageTitle"] = ViewData["Title"]?.ToString();
}

<div style="max-width:600px;">
    <a asp-area="Admin" asp-controller="Testimonials" asp-action="Index" class="btn btn-secondary" style="margin-bottom:20px;">
        <i class="fas fa-arrow-left"></i> Listeye Dön
    </a>

    <div style="background:white;padding:30px;border-radius:12px;box-shadow:0 2px 10px rgba(0,0,0,.05);">
        <h3 style="margin-bottom:25px;color:#333;">@ViewData["Title"]</h3>

        <form asp-area="Admin" asp-controller="Testimonials" asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? Model.Id : null)" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="StudentName">Öğrenci Adı *</label>
                <input asp-for="StudentName" placeholder="Örn: Ahmet Y." required>
                <span asp-validation-for="StudentName" style="color:#dc3545;font-size:13px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="StudentLevel">Öğrenim Seviyesi *</label>
                <input asp-for="StudentLevel" placeholder="Örn: 8. Sınıf / LGS Öğrencisi" required>
            </div>

            <div class="form-group">
                <label asp-for="Rating">Puan (1-5) *</label>
                <select asp-for="Rating" required>
                    <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                    <option value="4">⭐⭐⭐⭐ (4)</option>
                    <option value="3">⭐⭐⭐ (3)</option>
                    <option value="2">⭐⭐ (2)</option>
                    <option value="1">⭐ (1)</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="Comment">Yorum *</label>
                <textarea asp-for="Comment" rows="5" placeholder="Öğrencinin yorumunu buraya yazın..." required></textarea>
                <span asp-validation-for="Comment" style="color:#dc3545;font-size:13px;"></span>
            </div>

            <div class="form-group" style="display:flex;align-items:center;gap:10px;">
                <input asp-for="IsActive" type="checkbox" style="width:auto;">
                <label asp-for="IsActive" style="margin-bottom:0;">Sitede Göster (Aktif)</label>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;margin-top:10px;">
                <i class="fas fa-save"></i> @(isEdit ? "Güncelle" : "Oluştur")
            </button>
        </form>
    </div>
</div>
