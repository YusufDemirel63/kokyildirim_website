@model MakAkademi.Models.Entities.AvailableTimeSlot
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Zaman Dilimi Düzenle" : "Yeni Zaman Dilimi";
    ViewData["PageTitle"] = ViewData["Title"]?.ToString();
}

<div style="max-width:600px;">
    <a asp-area="Admin" asp-controller="TimeSlots" asp-action="Index" class="btn btn-secondary" style="margin-bottom:20px;">
        <i class="fas fa-arrow-left"></i> Listeye Dön
    </a>

    <div style="background:white;padding:30px;border-radius:12px;box-shadow:0 2px 10px rgba(0,0,0,.05);">
        <h3 style="margin-bottom:25px;color:#333;">@ViewData["Title"]</h3>

        <form asp-area="Admin" asp-controller="TimeSlots" asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? Model.Id : null)" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Date">Tarih *</label>
                <input asp-for="Date" type="date" required>
                <span asp-validation-for="Date" style="color:#dc3545;font-size:13px;"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:15px;">
                <div class="form-group">
                    <label asp-for="StartTime">Başlangıç Saati *</label>
                    <input asp-for="StartTime" type="time" required>
                </div>
                <div class="form-group">
                    <label asp-for="EndTime">Bitiş Saati *</label>
                    <input asp-for="EndTime" type="time" required>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="LessonType">Ders Türü *</label>
                <select asp-for="LessonType" required>
                    <option value="2">Her İkisi (Online & Yüz Yüze)</option>
                    <option value="0">Online</option>
                    <option value="1">Yüz Yüze</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="Notes">Notlar (Opsiyonel)</label>
                <input asp-for="Notes" placeholder="Örn: Sınav haftası müsait değil">
            </div>

            <div class="form-group" style="display:flex;align-items:center;gap:10px;">
                <input asp-for="IsAvailable" type="checkbox" style="width:auto;">
                <label asp-for="IsAvailable" style="margin-bottom:0;">Müsait</label>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;margin-top:10px;">
                <i class="fas fa-save"></i> @(isEdit ? "Güncelle" : "Oluştur")
            </button>
        </form>
    </div>
</div>
