@model MakAkademi.Models.Entities.ReservationRequest
@{
    ViewData["Title"] = "Rezervasyon Detayı";
    ViewData["PageTitle"] = "Rezervasyon Detayı";
    var trCulture = new System.Globalization.CultureInfo("tr-TR");
}

<div style="max-width:700px;">
    <a asp-area="Admin" asp-controller="Reservations" asp-action="Index" class="btn btn-secondary" style="margin-bottom:20px;">
        <i class="fas fa-arrow-left"></i> Listeye Dön
    </a>

    <div style="background:white;padding:30px;border-radius:12px;box-shadow:0 2px 10px rgba(0,0,0,.05);">
        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:25px;flex-wrap:wrap;gap:10px;">
            <h3 style="color:#333;">@Model.Name</h3>
            @{
                var (bg, fg) = Model.Status switch {
                    MakAkademi.Models.Entities.ReservationStatus.Onaylandi => ("#d4edda", "#155724"),
                    MakAkademi.Models.Entities.ReservationStatus.Iptal => ("#f8d7da", "#721c24"),
                    MakAkademi.Models.Entities.ReservationStatus.Tamamlandi => ("#e8f5e9", "#1b5e20"),
                    _ => ("#fff3e0", "#856404")
                };
            }
            <span style="padding:5px 15px;border-radius:6px;font-weight:600;background:@bg;color:@fg;">@Model.Status</span>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:25px;">
            <div><strong>E-posta:</strong><br><a href="mailto:@Model.Email">@Model.Email</a></div>
            <div><strong>Telefon:</strong><br><a href="tel:@Model.Phone">@Model.Phone</a></div>
            <div><strong>Eğitim Seviyesi:</strong><br>@Model.EducationLevel</div>
            <div><strong>Ders Türü:</strong><br>@Model.LessonType</div>
            @if (Model.SelectedDate.HasValue)
            {
                <div><strong>Seçilen Tarih:</strong><br>@Model.SelectedDate.Value.ToString("dd MMMM yyyy", trCulture)</div>
                <div><strong>Seçilen Saat:</strong><br>@Model.SelectedTime?.ToString("HH:mm")</div>
            }
            <div><strong>Talep Tarihi:</strong><br>@Model.CreatedAt.ToString("dd MMMM yyyy HH:mm", trCulture)</div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div style="background:#f8f9fa;padding:15px;border-radius:8px;border-left:4px solid #1E90FF;margin-bottom:25px;">
                <strong>Ek Mesaj:</strong>
                <p style="margin-top:8px;">@Model.Message</p>
            </div>
        }

        @if (Model.Status == MakAkademi.Models.Entities.ReservationStatus.Beklemede)
        {
            <div style="display:flex;gap:15px;flex-wrap:wrap;">
                <form asp-area="Admin" asp-controller="Reservations" asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id">
                    <input type="hidden" name="status" value="1">
                    <button type="submit" class="btn btn-success"><i class="fas fa-check"></i> Onayla</button>
                </form>
                <form asp-area="Admin" asp-controller="Reservations" asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id">
                    <input type="hidden" name="status" value="2">
                    <button type="submit" class="btn btn-danger"><i class="fas fa-times"></i> Reddet</button>
                </form>
                <a href="https://wa.me/90@(Model.Phone.Replace(" ","").Replace("-","").TrimStart('0'))" target="_blank" class="btn btn-success">
                    <i class="fab fa-whatsapp"></i> WhatsApp ile Yaz
                </a>
            </div>
        }
    </div>
</div>
