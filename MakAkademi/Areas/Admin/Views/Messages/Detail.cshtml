@model MakAkademi.Models.Entities.ContactMessage
@{
    ViewData["Title"] = "Mesaj Detayı";
    ViewData["PageTitle"] = "Mesaj Detayı";
    var trCulture = new System.Globalization.CultureInfo("tr-TR");
}

<div style="max-width:680px;">
    <a asp-area="Admin" asp-controller="Messages" asp-action="Index" class="btn btn-secondary" style="margin-bottom:20px;">
        <i class="fas fa-arrow-left"></i> Listeye Dön
    </a>

    <div style="background:white;padding:30px;border-radius:12px;box-shadow:0 2px 10px rgba(0,0,0,.05);">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:25px;">
            <div><strong>Ad Soyad:</strong><br>@Model.Name</div>
            <div><strong>E-posta:</strong><br><a href="mailto:@Model.Email">@Model.Email</a></div>
            <div><strong>Telefon:</strong><br><a href="tel:@Model.Phone">@Model.Phone</a></div>
            <div><strong>Konu:</strong><br>@Model.Subject</div>
            <div><strong>Tarih:</strong><br>@Model.CreatedAt.ToString("dd MMMM yyyy HH:mm", trCulture)</div>
            <div><strong>Durum:</strong><br>
                <span style="color:@(Model.IsRead ? "#888" : "#FF9800");font-weight:600;">
                    @(Model.IsRead ? "✓ Okundu" : "⦿ Okunmadı")
                </span>
            </div>
        </div>

        <div style="background:#f8f9fa;padding:20px;border-radius:8px;border-left:4px solid #1E90FF;margin-bottom:25px;">
            <strong>Mesaj:</strong>
            <p style="margin-top:10px;white-space:pre-wrap;">@Model.Message</p>
        </div>

        <div style="display:flex;gap:15px;flex-wrap:wrap;">
            <a href="mailto:@Model.Email?subject=Re: @Model.Subject" class="btn btn-success">
                <i class="fas fa-reply"></i> E-posta ile Yanıtla
            </a>
            <a href="https://wa.me/90@(Model.Phone.Replace(" ","").Replace("-","").TrimStart('0'))" target="_blank" class="btn btn-success">
                <i class="fab fa-whatsapp"></i> WhatsApp ile Yaz
            </a>
            <form asp-area="Admin" asp-controller="Messages" asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bu mesajı silmek istiyor musunuz?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Sil</button>
            </form>
        </div>
    </div>
</div>
