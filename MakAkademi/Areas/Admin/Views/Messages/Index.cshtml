@model IEnumerable<MakAkademi.Models.Entities.ContactMessage>
@{
    ViewData["Title"] = "Mesajlar";
    ViewData["PageTitle"] = "İletişim Mesajları";
    var trCulture = new System.Globalization.CultureInfo("tr-TR");
}

<table>
    <thead>
        <tr>
            <th>Ad Soyad</th>
            <th>E-posta / Telefon</th>
            <th>Konu</th>
            <th>Durum</th>
            <th>Tarih</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="6" style="text-align:center;padding:30px;color:#888;">Henüz mesaj bulunmuyor.</td></tr>
        }
        @foreach (var m in Model)
        {
            <tr style="@(!m.IsRead ? "background:#fffbf0;" : "")">
                <td data-label="Ad Soyad">
                    <strong>@m.Name</strong>
                    @if (!m.IsRead)
                    {
                        <span style="font-size:10px;padding:2px 6px;background:#FF9800;color:white;border-radius:3px;margin-left:5px;">YENİ</span>
                    }
                </td>
                <td data-label="İletişim">
                    <div><a href="mailto:@m.Email">@m.Email</a></div>
                    <div style="font-size:13px;color:#888;">@m.Phone</div>
                </td>
                <td data-label="Konu">@m.Subject</td>
                <td data-label="Durum">
                    @if (m.IsRead)
                    {
                        <span style="color:#888;"><i class="fas fa-check"></i> Okundu</span>
                    }
                    else
                    {
                        <span style="color:#FF9800;font-weight:600;"><i class="fas fa-envelope"></i> Okunmadı</span>
                    }
                </td>
                <td data-label="Tarih">@m.CreatedAt.ToString("dd MMM yyyy HH:mm", trCulture)</td>
                <td data-label="İşlemler">
                    <div class="table-actions">
                        <a asp-area="Admin" asp-controller="Messages" asp-action="Detail" asp-route-id="@m.Id" class="btn btn-primary btn-sm">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a href="mailto:@m.Email" class="btn btn-success btn-sm" title="E-posta Gönder">
                            <i class="fas fa-reply"></i>
                        </a>
                        <form asp-area="Admin" asp-controller="Messages" asp-action="Delete" asp-route-id="@m.Id" method="post" style="display:inline" onsubmit="return confirm('Bu mesajı silmek istiyor musunuz?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
