@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Dashboard";
    var stats = ViewBag.Stats;
}

<div class="stats-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-bottom:30px;">
    <div class="stat-card" style="background:white;border-radius:12px;padding:25px;box-shadow:0 2px 10px rgba(0,0,0,.05);display:flex;align-items:center;gap:20px;">
        <div style="width:60px;height:60px;border-radius:12px;background:linear-gradient(135deg,#1E90FF,#0D47A1);display:flex;align-items:center;justify-content:center;color:white;font-size:24px;">
            <i class="fas fa-calendar-check"></i>
        </div>
        <div>
            <h3 style="font-size:32px;font-weight:700;color:#333;">@stats.TotalReservations</h3>
            <p style="color:#888;font-size:14px;">Toplam Rezervasyon</p>
            <span style="font-size:12px;color:#FF9800;font-weight:600;">@stats.PendingReservations beklemede</span>
        </div>
    </div>
    <div class="stat-card" style="background:white;border-radius:12px;padding:25px;box-shadow:0 2px 10px rgba(0,0,0,.05);display:flex;align-items:center;gap:20px;">
        <div style="width:60px;height:60px;border-radius:12px;background:linear-gradient(135deg,#28a745,#1e7e34);display:flex;align-items:center;justify-content:center;color:white;font-size:24px;">
            <i class="fas fa-eye"></i>
        </div>
        <div>
            <h3 style="font-size:32px;font-weight:700;color:#333;">@stats.TodayViews</h3>
            <p style="color:#888;font-size:14px;">Bugünkü Ziyaretler</p>
            <span style="font-size:12px;color:#28a745;font-weight:600;">@stats.UniqueVisitorsToday benzersiz</span>
        </div>
    </div>
    <div class="stat-card" style="background:white;border-radius:12px;padding:25px;box-shadow:0 2px 10px rgba(0,0,0,.05);display:flex;align-items:center;gap:20px;">
        <div style="width:60px;height:60px;border-radius:12px;background:linear-gradient(135deg,#FF7F50,#e55a2b);display:flex;align-items:center;justify-content:center;color:white;font-size:24px;">
            <i class="fas fa-envelope"></i>
        </div>
        <div>
            <h3 style="font-size:32px;font-weight:700;color:#333;">@stats.UnreadMessages</h3>
            <p style="color:#888;font-size:14px;">Okunmamış Mesaj</p>
        </div>
    </div>
    <div class="stat-card" style="background:white;border-radius:12px;padding:25px;box-shadow:0 2px 10px rgba(0,0,0,.05);display:flex;align-items:center;gap:20px;">
        <div style="width:60px;height:60px;border-radius:12px;background:linear-gradient(135deg,#FFD166,#ffa000);display:flex;align-items:center;justify-content:center;color:white;font-size:24px;">
            <i class="fas fa-clock"></i>
        </div>
        <div>
            <h3 style="font-size:32px;font-weight:700;color:#333;">@stats.AvailableSlots</h3>
            <p style="color:#888;font-size:14px;">Müsait Slot</p>
            <span style="font-size:12px;color:#888;">@stats.TotalSlots toplam</span>
        </div>
    </div>
</div>

<div class="section-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:30px;">
    <div style="background:white;border-radius:12px;padding:25px;box-shadow:0 2px 10px rgba(0,0,0,.05);">
        <h3 style="margin-bottom:20px;color:#333;">Son Rezervasyonlar</h3>
        @if (ViewBag.RecentReservations != null)
        {
            <table>
                <thead><tr><th>Ad Soyad</th><th>Seviye</th><th>Durum</th></tr></thead>
                <tbody>
                    @foreach (var r in ViewBag.RecentReservations)
                    {
                        <tr>
                            <td>@r.Name</td>
                            <td>@r.EducationLevel</td>
                            <td><span style="font-size:12px;padding:3px 8px;border-radius:4px;background:#e3f2fd;color:#1E90FF;">@r.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <div style="margin-top:15px;">
            <a asp-area="Admin" asp-controller="Reservations" asp-action="Index" class="btn btn-primary">Tümünü Gör</a>
        </div>
    </div>

    <div style="background:white;border-radius:12px;padding:25px;box-shadow:0 2px 10px rgba(0,0,0,.05);">
        <h3 style="margin-bottom:20px;color:#333;">Son Mesajlar</h3>
        @if (ViewBag.RecentMessages != null)
        {
            <table>
                <thead><tr><th>Ad Soyad</th><th>Konu</th><th>Durum</th></tr></thead>
                <tbody>
                    @foreach (var m in ViewBag.RecentMessages)
                    {
                        <tr>
                            <td>@m.Name</td>
                            <td>@m.Subject</td>
                            <td>
                                @if (!m.IsRead)
                                {
                                    <span style="font-size:11px;padding:2px 8px;border-radius:4px;background:#fff3e0;color:#FF9800;font-weight:600;">YENİ</span>
                                }
                                else
                                {
                                    <span style="font-size:11px;color:#888;">Okundu</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <div style="margin-top:15px;">
            <a asp-area="Admin" asp-controller="Messages" asp-action="Index" class="btn btn-primary">Tümünü Gör</a>
        </div>
    </div>
</div>
