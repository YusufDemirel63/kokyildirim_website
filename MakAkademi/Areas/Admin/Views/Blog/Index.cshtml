@model IEnumerable<MakAkademi.Models.Entities.BlogPost>
@{
    ViewData["Title"] = "Blog Yazıları";
    ViewData["PageTitle"] = "Blog Yazıları";
    var trCulture = new System.Globalization.CultureInfo("tr-TR");
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
    <h2 style="color:#333;">Blog Yazıları</h2>
    <a asp-area="Admin" asp-controller="Blog" asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Yazı
    </a>
</div>

<table>
    <thead>
        <tr>
            <th>Başlık</th>
            <th>Slug</th>
            <th>Yayın Durumu</th>
            <th>Yorum</th>
            <th>Tarih</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="6" style="text-align:center;padding:30px;color:#888;">Henüz blog yazısı eklenmemiş.</td></tr>
        }
        @foreach (var p in Model)
        {
            <tr>
                <td data-label="Başlık">
                    <strong>@p.Title</strong>
                    @if (!string.IsNullOrEmpty(p.Excerpt))
                    {
                        <br><small style="color:#888;">@(p.Excerpt.Length > 50 ? p.Excerpt[..50] + "..." : p.Excerpt)</small>
                    }
                </td>
                <td data-label="Slug"><code style="font-size:12px;">@p.Slug</code></td>
                <td data-label="Yayın Durumu">
                    @if (p.IsPublished)
                    {
                        <span style="color:#28a745;font-weight:600;"><i class="fas fa-globe"></i> Yayında</span>
                    }
                    else
                    {
                        <span style="color:#888;font-weight:600;"><i class="fas fa-eye-slash"></i> Taslak</span>
                    }
                </td>
                <td data-label="Yorum">@p.Comments.Count(c => c.IsApproved) onaylı</td>
                <td data-label="Tarih">@p.CreatedAt.ToString("dd MMM yyyy", trCulture)</td>
                <td data-label="İşlemler">
                    <div class="table-actions">
                        <a asp-area="Admin" asp-controller="Blog" asp-action="Edit" asp-route-id="@p.Id" class="btn btn-warning btn-sm">
                            <i class="fas fa-edit"></i>
                        </a>
                        <form asp-area="Admin" asp-controller="Blog" asp-action="TogglePublish" asp-route-id="@p.Id" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn @(p.IsPublished ? "btn-secondary" : "btn-success") btn-sm" title="@(p.IsPublished ? "Taslağa Al" : "Yayınla")">
                                <i class="fas fa-@(p.IsPublished ? "eye-slash" : "globe")"></i>
                            </button>
                        </form>
                        <form asp-area="Admin" asp-controller="Blog" asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:inline" onsubmit="return confirm('Bu blog yazısını silmek istiyor musunuz?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
